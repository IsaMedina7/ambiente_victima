version: '3.8'

networks:
  gaia_lab_net:
    driver: bridge
    ipam:
      config:
        - subnet: 10.5.0.0/24

services:
  # CAPA 1: Firewall (Sin reglas, solo forwarding)
  gaia_firewall:
    image: alpine
    container_name: gaia_firewall
    cap_add:
      - NET_ADMIN
    command: /bin/sh -c "apk add iptables && tail -f /dev/null"
    networks:
      gaia_lab_net:
        ipv4_address: 10.5.0.5

  # CAPA 2: Antivirus (Estado base)
  gaia_antivirus:
    image: clamav/clamav:latest
    container_name: gaia_antivirus
    networks:
      gaia_lab_net:
    volumes:
      - ./html:/scandir:ro

  # LA VÍCTIMA (Configuración estándar de Apache)
  victima_apache:
    image: httpd:2.4-alpine
    container_name: victima_apache
    networks:
      gaia_lab_net:
        ipv4_address: 10.5.0.10
    volumes:
      - ./html:/usr/local/apache2/htdocs/
    ports:
      - "8080:80"

  # HONEYPOT (Señuelo SSH)
  honeypot_gaia:
    image: cowrie/cowrie:latest
    container_name: honeypot_gaia
    networks:
      gaia_lab_net:
        ipv4_address: 10.5.0.20
    ports:
      - "2222:2222"

  # EL SNIFFER (Captura automática de .pcap)
  # Reemplaza al IDS complejo por ahora
  ids_sniffer:
    image: alpine
    container_name: ids_sniffer
    network_mode: "host" 
    volumes:
      - ./capturas_pcap:/capturas
      # Sincroniza la zona horaria con el host
      - /etc/localtime:/etc/localtime:ro
      - /etc/timezone:/etc/timezone:ro
    command: >
      sh -c "apk add --no-cache tcpdump && 
             NAME=$$(date +%Y-%m-%d_%H-%M-%S) &&
             tcpdump -i any -w /capturas/$$NAME.pcap"
    depends_on:
      - victima_apache
